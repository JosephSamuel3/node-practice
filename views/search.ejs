<!DOCTYPE html>
<html lang="en">
<head>
    <title><%= title %></title>
</head>
<body>
    <h1><%= title %></h1>
    <%- include("partials/errors.ejs") %>
    <form action="/search" method="get">
        <label for="firstName">First Name:</label>
        <input type="text" name="firstName" id="firstName" value="<%= query?.firstName || "" %>">
        <label for="lastName">Last Name:</label>
        <input type="text" name="lastName" id="lastName" value="<%= query?.lastName || "" %>">
        <label for="email">Email:</label>
        <input type="email" name="email" id="email" value="<%= query?.email || "" %>">
        <button type="submit">Search</button>
    </form>

    <% if (showResults) { %>
        <% if (users.length > 0) { %>
            <ul>
                <% users.forEach((user) => { %>
                    <li>
                        <%= user.id %>,
                        <strong><%= user.firstName %> <%= user.lastName %></strong>
                        <% if (user.email) { %> — <%= user.email %><% } %>
                        <% if (user.age) { %> • Age: <%= user.age %><% } %>
                        <% if (user.bio) { %>
                            <p><%= user.bio %></p>
                        <% } %>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <p>No results found for that search.</p>
        <% } %>
    <% } %>
    <a href="/">Back to home</a>
</body>
</html>